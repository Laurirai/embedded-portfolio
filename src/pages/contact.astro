---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout>

    <Navigation />

    <main class="page">

        <h1>Contact</h1>

        <p>
            If you'd like to discuss embedded software,
            firmware development,
            or potential opportunities,
            feel free to get in touch.
        </p>

        <div class="contact">

            <h2>Email</h2>

            <p>
                your.email@example.com
            </p>

            <h2>GitHub</h2>

            <p>

                <a href="https://github.com/Laurirai" target="_blank">
                    github.com/Laurirai
                </a>

            </p>

            <h2>LinkedIn</h2>

            <p>
                Coming Soon
            </p>

            <h2>Location</h2>

            <p>
                Finland
            </p>

        </div>

    </main>

</Layout>

<style>

.page{

    max-width:900px;

    margin:80px auto;

    padding:0 30px 80px;

}

.contact{

    margin-top:40px;

}

.contact h2{

    margin-top:35px;

}

a{

    color:#2563eb;

    text-decoration:none;

}

a:hover{

    text-decoration:underline;

}

</style>