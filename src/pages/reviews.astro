---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import ReviewCard from '../components/ReviewCard.astro';
---

<Layout>

    <Navigation />

    <main class="reviews">

        <h1>Game Reviews</h1>

        <p>

            Games that left a lasting impression on me.

            These aren't professional reviews—just my personal thoughts after finishing games that I think are worth talking about.

        </p>

        <ReviewCard

            title="Elden Ring"

            studio="FromSoftware"

            year="2022"

            description="The game that completely changed how I viewed video games."

            rating="9.5 / 10"

            genres={["Soulslike","Open World","RPG"]}

            image="/images/reviews/eldenring.jpg"

            link="/reviews/elden-ring"

        />

    </main>

</Layout>

<style>

.reviews{

    max-width:1000px;

    margin:80px auto;

}

.reviews h1{

    font-size:3rem;

}

.reviews>p{

    margin-bottom:50px;

    max-width:700px;

}

</style>