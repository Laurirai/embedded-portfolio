---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout>
	<Navigation />
  <main class="hero">

    <div class="intro">

        <h1>Hello, I'm Lauri Räisänen</h1>

        <p class="subtitle">

            Embedded Software Engineer
            <br>
            (4th year student)

        </p>

        <p class="description">

            I'm a fourth-year Embedded and Smart Systems student with a passion for firmware development, embedded software and electronics.

            I enjoy building practical systems where software interacts with real hardware—from medical devices to hobby electronics.

        </p>

        <div class="buttons">

            <a href="/projects" class="primary">

                View Projects

            </a>

            <a href="/resume">

                CV

            </a>

            <a href="https://github.com/Laurirai">

                GitHub

            </a>

        </div>

        <section class="journey">

          <h2>Journey</h2>

          <div class="journey-item">

          <span class="year">2024 – Present</span>

          <h3>Embedded & Smart Systems Engineering</h3>

        <p>
            Metropolia University of Applied Sciences
            <br />
            Expected graduation: Spring 2027 (or earlier)
        </p>

        </div>

        <div class="journey-item">

          <span class="year">2021 – 2024</span>

        <h3>Software Development</h3>

        <p>
            Keuda Vocational College
            <br />
            Information and Communication Technology
        </p>

        </div>

        <div class="journey-item">

          <span class="year">2017 – 2018</span>

        <h3>High School Graduation</h3>

        <p>
            Manistee High USA.
            <br />
            Normal highschool diploma with focus on wrestling
        </p>

        </div>

</section>

    </div>

    <div class="right">

    <div class="photo">
        <img src="/images/meitsi.jpg" alt="Profile">
    </div>

    <section class="tech">

        <h2>Technologies</h2>

        <div class="tags">
            <span>C</span>
            <span>C++</span>
            <span>Python</span>
            <span>FreeRTOS</span>
            <span>ESP32</span>
            <span>STM32</span>
            <span>Raspberry Pi</span>
            <span>Linux</span>
            <span>Git</span>
        </div>

        <hr>

        <section class="current">

        <h2>Currently Working On</h2>

        <div class="current-item">

          <h3>Pulse Oximeter</h3>

          <p>ESP32-C6 • MAX30102 • FreeRTOS</p>

        </div>

        <div class="current-item">

            <h3>STM32 PC Display</h3>

            <p>USB Serial • OLED Display • Spotify & System Stats</p>

        </div>

        <div class="current-item">

            <h3>Portfolio Website</h3>

            <p>Astro • GitHub Pages</p>

        </div>

</section>

    </section>

</div>

</main>
  <style>

.hero{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;

    gap:100px;

    margin-top:80px;
}

.intro{

    flex:2;

}

.photo{

    flex:1;
    display:flex;
    justify-content:center;
    max-width:320px;

}

.photo img{

    width:100%;
    border-radius:20px;
    transition:.3s;
    border:3px solid var(--accent);
    filter:
        brightness(0.75)
        
        saturate(0.92);

}

.photo img:hover{

    filter:brightness(1);

    transform:scale(1.02);

}

.subtitle{

    font-size:1.4rem;

    color:var(--muted);

}

.description{

    max-width:650px;

    font-size:1.1rem;

}

.hero h1{
    font-size: 3rem;
    margin-bottom: 10px;
}

.hero p{
    font-size: 1.2rem;
    line-height: 1.7;
}

.right{

    flex:1;

    display:flex;

    flex-direction:column;

    align-items:center;

    gap:40px;

}

.buttons{

    display:flex;

    gap:20px;

    margin-top:40px;

}

.buttons a{

    padding:14px 28px;

    border-radius:12px;

    border:2px solid var(--accent);

    transition:.2s;

}

.journey{

    margin-top:70px;

    padding-top:35px;

    border-top:1px solid var(--border);

    max-width:650px;

}

.journey h2{

    margin-bottom:30px;

    font-size:1.8rem;

}

.journey-item{

    margin-bottom:35px;

}

.year{

    color:var(--accent);

    font-weight:700;

    letter-spacing:.05em;

}

.journey-item h3{

    margin:8px 0;

    font-size:1.2rem;

}

.journey-item p{

    margin:0;

    color:var(--muted);

    line-height:1.6;

}

.primary{

    background:var(--accent);

}

.primary:hover{

    background:var(--accent-hover);

}

.buttons a:hover{

    transform:translateY(-2px);

}

.tech{

    max-width:900px;

}

.tags{

    display:flex;

    flex-wrap:wrap;

    gap:15px;

}

.tags span{

    padding:10px 18px;

    background:var(--card);

    border:1px solid var(--border);

    border-radius:999px;

}

.tech hr{

    border:none;

    border-top:1px solid var(--border);

    margin:35px 0;

}

.current h2{

    margin-bottom:25px;

}

.current-item{

    margin-bottom:25px;

}

.current-item h3{

    margin-bottom:6px;

    font-size:1.1rem;

}

.current-item p{

    color:var(--muted);

    margin:0;

}

</style>
</Layout>